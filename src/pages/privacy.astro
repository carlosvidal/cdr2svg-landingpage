---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Privacy Policy — CDR2SVG">
  <Navbar />
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-20">
    <h1 class="font-display text-4xl font-bold tracking-tight mb-8">Privacy Policy</h1>
    <div class="prose prose-invert prose-sm text-white/50 space-y-6 leading-relaxed">
      <p>CDR2SVG processes all files locally on your Mac. No files are uploaded to any server.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">What we collect</h2>
      <p>When you purchase a license, we collect your email address and payment information through PayPal. We store a hashed version of your license key and your email to validate activations.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">What we don't collect</h2>
      <p>We do not collect, store, or transmit any files you process with CDR2SVG. We do not use analytics or tracking on the app itself.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">Contact</h2>
      <p>Questions? Email <a href="mailto:support@cdr2svg.com" class="text-accent hover:underline">support@cdr2svg.com</a>.</p>
    </div>
  </main>
  <Footer />
</Base>
