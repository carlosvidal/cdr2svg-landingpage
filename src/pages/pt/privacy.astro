---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n/index';
const lang = 'pt';
const i = t(lang);
---

<Base title={`${i.privacy.title} — CDR2SVG`} lang={lang}>
  <Navbar lang={lang} />
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-20">
    <h1 class="font-display text-4xl font-bold tracking-tight mb-8">{i.privacy.title}</h1>
    <div class="prose prose-invert prose-sm text-white/50 space-y-6 leading-relaxed">
      <p>{i.privacy.intro}</p>
      <h2 class="font-display text-lg text-white/80 mt-8">{i.privacy.collectTitle}</h2>
      <p>{i.privacy.collectText}</p>
      <h2 class="font-display text-lg text-white/80 mt-8">{i.privacy.noCollectTitle}</h2>
      <p>{i.privacy.noCollectText}</p>
      <h2 class="font-display text-lg text-white/80 mt-8">{i.privacy.contactTitle}</h2>
      <p>{i.privacy.contactText} <a href="mailto:support@cdr2svg.com" class="text-accent hover:underline">support@cdr2svg.com</a>.</p>
    </div>
  </main>
  <Footer lang={lang} />
</Base>
