---
import Base from '../layouts/Base.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Terms of Service — CDR2SVG">
  <Navbar />
  <main class="max-w-3xl mx-auto px-6 pt-32 pb-20">
    <h1 class="font-display text-4xl font-bold tracking-tight mb-8">Terms of Service</h1>
    <div class="prose prose-invert prose-sm text-white/50 space-y-6 leading-relaxed">
      <h2 class="font-display text-lg text-white/80 mt-8">License</h2>
      <p>Each license key activates CDR2SVG on one Mac. The license is perpetual — it does not expire. Free updates are included for one year from purchase.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">Refunds</h2>
      <p>We offer a 14-day refund policy. If CDR2SVG doesn't work for your use case, contact us and we'll process a full refund.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">Disclaimer</h2>
      <p>CDR2SVG is provided "as is" without warranties of any kind. File conversion accuracy depends on the source file and CDR format version.</p>
      <h2 class="font-display text-lg text-white/80 mt-8">Contact</h2>
      <p>Email <a href="mailto:support@cdr2svg.com" class="text-accent hover:underline">support@cdr2svg.com</a>.</p>
    </div>
  </main>
  <Footer />
</Base>
