---
import { type Lang, defaultLang, languages } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);
const prefix = lang === defaultLang ? '' : `/${lang}`;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/[0.06] backdrop-blur-xl bg-surface/80">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between relative">
    <!-- Logo -->
    <a href={`${prefix}/`} class="absolute left-1/2 -translate-x-1/2 sm:static sm:translate-x-0 flex items-center group transition-transform group-hover:scale-[1.02]">
      <img src="/cdr2svg-logo.svg" alt="CDR2SVG" class="h-10 sm:h-8" />
    </a>

    <!-- Links -->
    <div class="hidden md:flex items-center gap-8 text-sm text-white/50">
      <a href="#features" class="hover:text-white transition-colors duration-200">{i.nav.features}</a>
      <a href="#how-it-works" class="hover:text-white transition-colors duration-200">{i.nav.howItWorks}</a>
      <a href="#pricing" class="hover:text-white transition-colors duration-200">{i.nav.pricing}</a>
      <a href="#faq" class="hover:text-white transition-colors duration-200">{i.nav.faq}</a>
    </div>

    <!-- Right side: Language selector + CTA -->
    <div class="flex items-center gap-3">
      <!-- Language selector -->
      <div class="relative group">
        <button class="flex items-center gap-1 px-2 py-1.5 rounded-lg text-xs text-white/40 hover:text-white/60 border border-transparent hover:border-white/[0.08] transition-all duration-200 cursor-pointer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="opacity-50">
            <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          <span class="uppercase">{lang}</span>
        </button>
        <div class="absolute right-0 top-full mt-1 py-1 bg-surface-100 border border-white/[0.08] rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 min-w-[140px] z-50">
          {Object.entries(languages).map(([code, name]) => (
            <a
              href={code === defaultLang ? '/' : `/${code}/`}
              class={`block px-3 py-1.5 text-xs transition-colors ${code === lang ? 'text-accent' : 'text-white/40 hover:text-white/70'}`}
            >
              {name}
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <a
        href="https://cdn.cdr2svg.com/CDR2SVG.dmg"
        onclick="gtag('event','file_download',{file_name:'CDR2SVG.dmg',link_text:'navbar_download'})"
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent/10 text-accent text-sm font-medium border border-accent/20 hover:bg-accent/20 hover:border-accent/30 transition-all duration-200"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1V10M7 10L3.5 6.5M7 10L10.5 6.5M2 13H12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {i.nav.download}
      </a>
    </div>
  </div>
</nav>
