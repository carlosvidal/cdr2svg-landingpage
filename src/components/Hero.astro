---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);
---

<section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-accent/[0.07] rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-accent/[0.04] rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-6 text-center py-24">
    <!-- Version badge -->
    <div class="reveal inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/[0.08] bg-white/[0.03] text-xs text-white/40 font-mono mb-10">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      {i.hero.badge}
    </div>

    <!-- Headline -->
    <h1 class="reveal reveal-delay-1 font-display text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-[1.05] mb-6">
      {i.hero.headline}<br />
      <span class="bg-gradient-to-r from-accent via-accent-glow to-accent bg-clip-text text-transparent">{i.hero.headlineAccent}</span>
    </h1>

    <!-- Subheadline -->
    <p class="reveal reveal-delay-2 text-lg sm:text-xl text-white/50 max-w-2xl mx-auto leading-relaxed mb-8" set:html={i.hero.subheadline.replace(/<code>/g, '<code class="text-white/70 bg-white/[0.06] px-1.5 py-0.5 rounded text-[0.9em] font-mono">')} />

    <!-- Expanded description -->
    <p class="reveal reveal-delay-3 text-sm text-white/30 max-w-xl mx-auto leading-relaxed mb-12" set:html={i.hero.description.replace(/<code>/g, '<code class="font-mono text-white/40">')} />

    <!-- CTAs -->
    <div class="reveal reveal-delay-4 flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <!-- Primary -->
      <a href="https://cdn.cdr2svg.com/CDR2SVG.dmg" onclick="gtag('event','file_download',{file_name:'CDR2SVG.dmg',link_text:'hero_download'})" class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-accent text-surface font-display font-semibold text-base transition-all duration-300 hover:shadow-[0_0_40px_rgba(0,229,195,0.3)] hover:scale-[1.02]">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="transition-transform group-hover:-translate-y-0.5">
          <path d="M9 2V12M9 12L4.5 7.5M9 12L13.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M3 16H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {i.hero.cta}
      </a>
      <!-- Secondary -->
      <a href="#pricing" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border border-white/[0.1] text-white/70 font-display font-medium text-base hover:border-white/20 hover:text-white transition-all duration-300">
        {i.hero.ctaBuy}
      </a>
    </div>

    <p class="reveal reveal-delay-5 text-xs text-white/25 font-mono">
      {i.hero.footnote}
    </p>

    <!-- App preview mockup -->
    <div class="reveal mt-20 relative max-w-full overflow-hidden">
      <div class="relative rounded-2xl border border-white/[0.08] overflow-hidden shadow-2xl shadow-black/50">
        <img
          src="/cdr2svg-screenshot.webp"
          alt={i.hero.imgAlt}
          class="w-full h-auto"
          loading="eager"
        />
      </div>
      <!-- Glow beneath -->
      <div class="absolute -bottom-20 left-1/2 -translate-x-1/2 w-3/4 h-40 bg-accent/[0.06] rounded-full blur-[80px]"></div>
    </div>
  </div>
</section>
