---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);

const icons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="12" cy="12" r="4"/><path d="M3 12h4M17 12h4M12 3v4M12 17v4"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h6v6H4z"/><path d="M14 4h6v6h-6z"/><path d="M4 14h6v6H4z"/><path d="M14 14h6v6h-6z"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 10h12"/><path d="M4 14h16"/><path d="M4 18h8"/><rect x="17" y="14" width="5" height="5" rx="1"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M15 9l-6 6"/><circle cx="9" cy="9" r="1" fill="currentColor"/><circle cx="15" cy="15" r="1" fill="currentColor"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M12 15l-4-4M12 15l4-4"/><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
];
---

<section id="features" class="relative py-32 px-6">
  <!-- Subtle divider gradient -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <h2 class="reveal font-display text-4xl sm:text-5xl font-bold tracking-tight mb-4">
        {i.features.title}<br />
        <span class="text-white/40">{i.features.titleFaded}</span>
      </h2>
      <p class="reveal reveal-delay-1 text-white/30 text-lg">
        {i.features.subtitle}
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {i.features.items.map((feature, idx) => (
        <div class={`reveal reveal-delay-${Math.min(idx + 1, 5)} group relative p-7 rounded-2xl border border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/[0.1] transition-all duration-300`}>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-accent/[0.08] border border-accent/10 flex items-center justify-center text-accent mb-5 transition-all duration-300 group-hover:bg-accent/[0.12] group-hover:border-accent/20 group-hover:shadow-[0_0_20px_rgba(0,229,195,0.1)]" set:html={icons[idx]} />
          <!-- Title -->
          <h3 class="font-display font-semibold text-lg text-white mb-2">{feature.title}</h3>
          <!-- Description -->
          <p class="text-sm text-white/40 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
