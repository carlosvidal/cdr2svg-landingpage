---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);
const prefix = lang === defaultLang ? '' : `/${lang}`;
---

<section id="pricing" class="relative py-32 px-6">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/[0.04] rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-xl mx-auto text-center">
    <!-- Section header -->
    <h2 class="reveal font-display text-4xl sm:text-5xl font-bold tracking-tight mb-4">
      {i.pricing.title} <span class="text-accent">{i.pricing.titleAccent}</span>
    </h2>
    <p class="reveal reveal-delay-1 text-white/40 text-lg mb-14">
      {i.pricing.subtitle}
    </p>

    <!-- Pricing card -->
    <div class="reveal reveal-delay-2 relative rounded-2xl border border-accent/20 bg-surface-100 overflow-hidden">
      <!-- Top accent line -->
      <div class="h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>

      <div class="p-8 sm:p-10">
        <!-- Plan name -->
        <div class="font-display font-semibold text-xl mb-2">{i.pricing.planName}</div>

        <!-- Price -->
        <div class="flex items-baseline justify-center gap-1 mb-8">
          <span class="font-display text-5xl font-bold text-white">{i.pricing.price}</span>
          <span class="text-white/30 text-sm">{i.pricing.priceLabel}</span>
        </div>

        <!-- Features list -->
        <ul class="space-y-3 mb-10 text-left max-w-xs mx-auto">
          {i.pricing.features.map((feature) => (
            <li class="flex items-start gap-3 text-sm text-white/60">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="text-accent flex-shrink-0 mt-0.5">
                <path d="M4 9L7.5 12.5L14 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {feature}
            </li>
          ))}
        </ul>

        <!-- Email input (shown before PayPal) -->
        <div id="email-step" class="mb-4">
          <label for="buyer-email" class="block text-left text-xs text-white/30 mb-2 font-mono">{i.pricing.emailLabel}</label>
          <input
            type="email"
            id="buyer-email"
            placeholder={i.pricing.emailPlaceholder}
            required
            class="w-full px-4 py-3 rounded-lg bg-surface-200 border border-white/[0.08] text-white text-sm placeholder:text-white/20 focus:outline-none focus:border-accent/40 focus:ring-1 focus:ring-accent/20 transition-all font-body"
          />
          <button
            id="continue-to-pay"
            class="w-full mt-3 py-4 rounded-xl bg-accent text-surface font-display font-semibold text-base transition-all duration-300 hover:shadow-[0_0_40px_rgba(0,229,195,0.3)] hover:scale-[1.01] cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:shadow-none disabled:hover:scale-100"
            disabled
          >
            {i.pricing.continueToPay}
          </button>
        </div>

        <!-- PayPal button container (shown after email validated) -->
        <div id="paypal-button-container" class="hidden"></div>

        <!-- Status messages -->
        <div id="payment-status" class="hidden mt-4 p-3 rounded-lg text-sm font-medium"></div>

        <p id="paypal-footer-text" class="mt-5 text-xs text-white/20">
          {i.pricing.secureCheckout}
        </p>
      </div>
    </div>

    <!-- Note -->
    <p class="reveal reveal-delay-3 mt-8 text-sm text-white/30 font-mono">
      {i.pricing.footnote}
    </p>
  </div>
</section>

<!-- Pass translations to JS -->
<script is:inline define:vars={{ pricingI18n: { processing: i.pricing.processing, paypalLoading: i.pricing.paypalLoading, paymentFailed: i.pricing.paymentFailed, paymentError: i.pricing.paymentError, paymentCancelled: i.pricing.paymentCancelled }, graciasUrl: `${prefix}/gracias` }}>
window.__pricingI18n = pricingI18n;
window.__graciasUrl = graciasUrl;
</script>

<!-- PayPal SDK -->
<script is:inline src="https://www.paypal.com/sdk/js?client-id=AVtwY5-kTCKCGU6O5s1Rknw9JWW_Z0S2HLK_dJg_7vErkjsLVzq_khQbKDrSF36-SbEu4Sp0LwQOQJRP&currency=USD&intent=capture&components=buttons&disable-funding=card" data-namespace="paypal_sdk"></script>

<script is:inline>
(function () {
  var i18n = window.__pricingI18n || {};
  var graciasUrl = window.__graciasUrl || '/gracias';

  var API_BASE = window.location.hostname === 'localhost'
    ? 'http://localhost:3000'
    : 'https://license-api.cdr2svg.com';

  var emailInput = document.getElementById('buyer-email');
  var continueBtn = document.getElementById('continue-to-pay');
  var emailStep = document.getElementById('email-step');
  var paypalContainer = document.getElementById('paypal-button-container');
  var statusEl = document.getElementById('payment-status');

  function isValidEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  emailInput.addEventListener('input', function () {
    continueBtn.disabled = !isValidEmail(this.value.trim());
  });

  continueBtn.addEventListener('click', function () {
    var email = emailInput.value.trim();
    if (!isValidEmail(email)) return;

    emailStep.style.display = 'none';
    paypalContainer.classList.remove('hidden');

    renderPayPalButtons(email);
  });

  function showStatus(message, type) {
    statusEl.textContent = message;
    statusEl.className = 'mt-4 p-3 rounded-lg text-sm font-medium';
    if (type === 'error') {
      statusEl.className += ' bg-red-500/10 border border-red-500/20 text-red-400';
    } else if (type === 'success') {
      statusEl.className += ' bg-accent/10 border border-accent/20 text-accent';
    } else {
      statusEl.className += ' bg-white/[0.04] border border-white/[0.08] text-white/50';
    }
    statusEl.classList.remove('hidden');
  }

  function renderPayPalButtons(email) {
    if (typeof paypal_sdk === 'undefined') {
      showStatus(i18n.paypalLoading || 'PayPal is loading, please wait...', 'info');
      setTimeout(function () { renderPayPalButtons(email); }, 1000);
      return;
    }

    paypal_sdk.Buttons({
      style: {
        layout: 'vertical',
        color: 'black',
        shape: 'rect',
        label: 'pay',
        height: 50,
      },

      createOrder: function () {
        return fetch(API_BASE + '/api/v1/paypal/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan: 'personal' }),
        })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (data.orderID) return data.orderID;
            throw new Error(data.message || 'Could not create order');
          });
      },

      onApprove: function (data) {
        showStatus(i18n.processing || 'Processing payment...', 'info');

        return fetch(API_BASE + '/api/v1/paypal/capture-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderID: data.orderID, email: email }),
        })
          .then(function (res) { return res.json(); })
          .then(function (result) {
            if (result.success) {
              window.location.href = graciasUrl;
            } else {
              showStatus(result.message || i18n.paymentFailed || 'Payment failed. Please try again.', 'error');
            }
          });
      },

      onError: function (err) {
        console.error('PayPal error:', err);
        showStatus(i18n.paymentError || 'Something went wrong. Please try again.', 'error');
      },

      onCancel: function () {
        showStatus(i18n.paymentCancelled || 'Payment cancelled. You can try again whenever you\'re ready.', 'info');
      },
    }).render('#paypal-button-container');
  }
})();
</script>
