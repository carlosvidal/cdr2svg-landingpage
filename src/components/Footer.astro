---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);
const prefix = lang === defaultLang ? '' : `/${lang}`;
---

<footer class="relative border-t border-white/[0.06] py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo -->
      <div class="flex items-center">
        <img src="/cdr2svg-logo.svg" alt="CDR2SVG" class="h-6 opacity-60" />
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-white/30">
        <a href={`${prefix}/privacy`} class="hover:text-white/60 transition-colors">{i.footer.privacy}</a>
        <a href={`${prefix}/terms`} class="hover:text-white/60 transition-colors">{i.footer.terms}</a>
        <a href="mailto:support@cdr2svg.com" class="hover:text-white/60 transition-colors">{i.footer.support}</a>
        <a href={`${prefix}/drop2jpg`} class="hover:text-white/60 transition-colors">{i.footer.drop2jpg}</a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-white/20 font-mono">
        &copy; {new Date().getFullYear()} CDR2SVG
      </p>
    </div>
  </div>
</footer>
