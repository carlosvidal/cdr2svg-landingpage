<footer class="relative border-t border-white/[0.06] py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo -->
      <div class="flex items-center">
        <img src="/cdr2svg-logo.svg" alt="CDR2SVG" class="h-6 opacity-60" />
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-white/30">
        <a href="/privacy" class="hover:text-white/60 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white/60 transition-colors">Terms</a>
        <a href="mailto:support@cdr2svg.com" class="hover:text-white/60 transition-colors">Support</a>
      </div>

      <!-- Copyright -->
      <p class="text-xs text-white/20 font-mono">
        &copy; {new Date().getFullYear()} CDR2SVG
      </p>
    </div>
  </div>
</footer>
