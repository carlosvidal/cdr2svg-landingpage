---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);

const visuals = [
  `<svg viewBox="0 0 120 80" fill="none" class="w-full h-full text-accent/40"><rect x="10" y="10" width="100" height="60" rx="8" stroke="currentColor" stroke-width="1" stroke-dasharray="6 3"/><path d="M60 25V55M60 55L48 43M60 55L72 43" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><text x="60" y="72" text-anchor="middle" fill="currentColor" font-size="8" font-family="monospace" opacity="0.6">.cdr</text></svg>`,
  `<svg viewBox="0 0 120 80" fill="none" class="w-full h-full text-accent/40"><rect x="10" y="10" width="100" height="60" rx="8" stroke="currentColor" stroke-width="1"/><circle cx="45" cy="40" r="12" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.1"/><polygon points="75,30 90,50 60,50" stroke="currentColor" stroke-width="1" fill="currentColor" fill-opacity="0.1"/><rect x="32" y="48" width="26" height="14" rx="2" stroke="currentColor" stroke-width="0.75" opacity="0.5"/></svg>`,
  `<svg viewBox="0 0 120 80" fill="none" class="w-full h-full text-accent/40"><rect x="20" y="15" width="32" height="20" rx="4" stroke="currentColor" stroke-width="1"/><text x="36" y="28" text-anchor="middle" fill="currentColor" font-size="7" font-family="monospace">SVG</text><rect x="60" y="15" width="32" height="20" rx="4" stroke="currentColor" stroke-width="1"/><text x="76" y="28" text-anchor="middle" fill="currentColor" font-size="7" font-family="monospace">EPS</text><rect x="20" y="45" width="32" height="20" rx="4" stroke="currentColor" stroke-width="1"/><text x="36" y="58" text-anchor="middle" fill="currentColor" font-size="7" font-family="monospace">PDF</text><rect x="60" y="45" width="32" height="20" rx="4" stroke="currentColor" stroke-width="1"/><text x="76" y="58" text-anchor="middle" fill="currentColor" font-size="7" font-family="monospace">AI</text><path d="M50 40L56 40" stroke="currentColor" stroke-width="1" opacity="0.3"/></svg>`,
];
const numbers = ['01', '02', '03'];
---

<section id="how-it-works" class="relative py-32 px-6">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <h2 class="reveal font-display text-4xl sm:text-5xl font-bold tracking-tight mb-4">
        {i.howItWorks.title} <span class="text-white/40">{i.howItWorks.titleFaded}</span>
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {i.howItWorks.steps.map((step, idx) => (
        <div class={`reveal reveal-delay-${idx + 1} relative group`}>
          <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-7 h-full hover:border-white/[0.1] transition-all duration-300">
            <!-- Step number -->
            <div class="font-mono text-xs text-accent/50 mb-6 tracking-widest">{numbers[idx]}</div>

            <!-- Visual -->
            <div class="w-full h-24 mb-6 opacity-60 group-hover:opacity-100 transition-opacity duration-300" set:html={visuals[idx]} />

            <!-- Title -->
            <h3 class="font-display font-semibold text-lg text-white mb-2">{step.title}</h3>
            <!-- Description -->
            <p class="text-sm text-white/40 leading-relaxed">{step.description}</p>
          </div>

          {/* Connector arrow (between cards on desktop) */}
          {idx < 2 && (
            <div class="hidden md:block absolute top-1/2 -right-3 z-10 text-white/10">
              <svg width="6" height="10" viewBox="0 0 6 10" fill="none">
                <path d="M1 1L5 5L1 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Narrative block -->
    <div class="reveal mt-16 relative rounded-2xl border border-white/[0.06] bg-white/[0.02] p-8 sm:p-10">
      <div class="absolute top-6 left-8 text-accent/20 text-4xl font-display leading-none">&ldquo;</div>
      <blockquote class="text-white/50 text-base sm:text-lg leading-relaxed max-w-3xl mx-auto pl-6">
        <p class="mb-4 italic text-white/60">
          {i.howItWorks.quote}
        </p>
        <p class="text-sm text-white/35 not-italic">
          {i.howItWorks.quoteFollow}
        </p>
      </blockquote>
    </div>
  </div>
</section>
