---
import { type Lang, defaultLang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang?: Lang; }
const lang: Lang = Astro.props.lang || defaultLang;
const i = t(lang);
---

<section id="faq" class="relative py-32 px-6">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

  <div class="max-w-2xl mx-auto">
    <!-- Section header -->
    <h2 class="reveal font-display text-4xl sm:text-5xl font-bold tracking-tight text-center mb-16">
      {i.faq.title}<span class="text-white/40">.</span>
    </h2>

    <!-- FAQ items -->
    <div class="space-y-4">
      {i.faq.items.map((faq, idx) => (
        <details class={`reveal reveal-delay-${Math.min(idx + 1, 5)} group rounded-xl border border-white/[0.06] bg-white/[0.02] transition-all duration-300 hover:border-white/[0.1]`}>
          <summary class="flex items-center justify-between gap-4 px-7 py-5 cursor-pointer list-none text-white font-display font-medium select-none [&::-webkit-details-marker]:hidden">
            {faq.question}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="text-white/30 flex-shrink-0 transition-transform duration-300 group-open:rotate-45">
              <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </summary>
          <div class="px-7 pb-6 text-sm text-white/40 leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
